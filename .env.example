# =============================================================================
# BorsaCI Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Provider Selection (credentials are stored in ~/.borsaci/credentials/)
# -----------------------------------------------------------------------------

# Option 1: OpenRouter (API Key)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Option 2: Google Gemini (OAuth)
# OAuth credentials are automatically resolved:
# 1. From installed Gemini CLI (npm install -g @google/gemini-cli)
# 2. Built-in Antigravity credentials (fallback)
#
# NOTE: Environment variable credentials are NOT supported for Google OAuth.
# Use 'login google' command in the CLI to authenticate.

# -----------------------------------------------------------------------------
# OpenRouter App Info (Optional - for rankings on openrouter.ai)
# -----------------------------------------------------------------------------
# HTTP_REFERER=https://borsaci.app
# X_TITLE=BorsaCI

# -----------------------------------------------------------------------------
# Borsa MCP Server (Optional - defaults to hosted server)
# -----------------------------------------------------------------------------
# BORSA_MCP_URL=https://borsamcp.fastmcp.app/mcp

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
MAX_STEPS=20
MAX_STEPS_PER_TASK=5

# Warren Buffett Agent (Optional - defaults to Gemini 3 Flash Preview)
# Use Pro for deeper reasoning (slower but more thorough)
# BUFFETT_MODEL=openrouter:google/gemini-3-pro-preview
# BUFFETT_MODEL=openrouter:google/gemini-3-flash-preview  # Default

# -----------------------------------------------------------------------------
# Performance Configuration
# -----------------------------------------------------------------------------
PARALLEL_EXECUTION=true
